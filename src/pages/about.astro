---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionNumber from '../components/SectionNumber.astro';
import Reveals from '../components/Reveals.astro';

const tools = ['Figma', 'Squarespace', 'Flutter', 'Adobe Suite'];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Federico de Servi',
  jobTitle: 'Designer, Brand-builder, Flutter Developer',
  description: 'Designer, brand-builder e flutter-dev a Milano. Lavoro con content creator italiani.',
  url: 'https://federicodeservi.com/about',
  knowsAbout: ['Design', 'Branding', 'Flutter', 'Editorial Design'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Milano',
    addressCountry: 'IT',
  },
};
---

<BaseLayout
  title="About"
  description="Federico de Servi, 1995, Milano. Designer e flutter-dev per content creator italiani. Come lavoro, con cosa, e cosa faccio fuori dal lavoro."
  jsonLd={jsonLd}
>
  <Reveals />

  <section class="section section--about-hero">
    <div class="section__inner grid">
      <div class="about-hero">
        <p class="t-mono about-hero__eyebrow" data-reveal>ABOUT</p>
        <h1 class="t-h1" data-reveal>Federico,<br /><span class="t-italic">1995, Milano.</span></h1>
      </div>
    </div>
  </section>

  <!-- 01 — Bio -->
  <section class="section">
    <div class="section__inner grid">
      <SectionNumber number="01" label="Bio" />
      <div class="about-block">
        <h2 class="t-h2" data-reveal>Bio.</h2>
        <p class="t-body-lg" data-reveal>
          Faccio design, brand e (quando serve) sviluppo, da Milano, principalmente in remoto. Ho una formazione tra design e tecnologia che mi permette di stare al tavolo del progetto dall'inizio alla fine.
        </p>
        <p class="t-body-lg" data-reveal>
          Ho iniziato facendo siti per amici, poi per amici di amici. Ho lavorato su prodotti digitali, libri, identità — sempre con persone che hanno qualcosa da dire e bisogno di un supporto serio per dirla bene.
        </p>
        <p class="t-body-lg" data-reveal>
          Lavoro meglio con creator italiani che hanno già una voce e vogliono trasformarla in un prodotto: un sito che si distingua, un'app che faccia esattamente una cosa, un libro che la gente apra davvero.
        </p>
        <p class="t-body-lg" data-reveal>
          Niente jargon, niente promesse di "scalare al next level". Faccio le cose come si farebbero per un amico che ti ha chiesto un favore — solo che adesso ti pago.
        </p>
      </div>
    </div>
  </section>

  <!-- 02 — Process -->
  <section class="section">
    <div class="section__inner grid">
      <SectionNumber number="02" label="Process" />
      <div class="about-block">
        <h2 class="t-h2" data-reveal>Process.</h2>
        <p class="t-body-lg" data-reveal>Come lavoro su un progetto, da intro call a delivery.</p>

        <ol class="process" data-reveal-group>
          <li class="process__item" data-reveal-item>
            <p class="t-mono process__num">02.1 — Discovery</p>
            <p class="t-body">Una call. Capire il problema reale, non quello che è arrivato in mail.</p>
          </li>
          <li class="process__item" data-reveal-item>
            <p class="t-mono process__num">02.2 — Direction</p>
            <p class="t-body">Un documento di direzione, due o tre opzioni. Si sceglie prima di costruire.</p>
          </li>
          <li class="process__item" data-reveal-item>
            <p class="t-mono process__num">02.3 — Build</p>
            <p class="t-body">Iterazioni asincrone. No surprises, niente "tadà" finale.</p>
          </li>
          <li class="process__item" data-reveal-item>
            <p class="t-mono process__num">02.4 — Handoff</p>
            <p class="t-body">Consegna + 30 giorni di supporto, per le cose che spuntano una volta che il progetto è vivo.</p>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- 03 — Tools -->
  <section class="section">
    <div class="section__inner grid">
      <SectionNumber number="03" label="Tools" />
      <div class="about-block">
        <h2 class="t-h2" data-reveal>Tools.</h2>
        <p class="t-body-lg" data-reveal>Quelli che uso davvero, niente "stack flex".</p>

        <ul class="tools" data-reveal-group>
          {tools.map((t) => (
            <li class="tools__item" data-reveal-item>
              <span class="t-h3">{t}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- 04 — Off-hours -->
  <section class="section">
    <div class="section__inner grid">
      <SectionNumber number="04" label="Off-hours" />
      <div class="about-block">
        <h2 class="t-h2" data-reveal>Off-hours.</h2>

        <div class="off-hours" data-reveal>
          <div class="off-hours__photo">
            <span>foto hobby · placeholder</span>
          </div>
          <p class="t-body-lg">
            Quando non lavoro, ascolto podcast italiani (sì, anche Power Pizza), provo a cucinare meglio di quanto sappia, e cerco scuse per andare a vedere mostre di design tipografico. A Milano, si trovano.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 05 — Get in touch -->
  <section class="section section--invert">
    <div class="section__inner grid">
      <SectionNumber number="05" label="Get in touch" />
      <div class="about-block">
        <h2 class="t-h2" data-reveal>Get in touch.</h2>
        <p class="t-body-lg" data-reveal>Hai un progetto in mente? Parliamone.</p>
        <p class="about-block__cta" data-reveal>
          <a href="/contact" class="btn" data-cursor="link">Scrivimi <span aria-hidden="true">→</span></a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section { padding: 8rem 0; position: relative; }
  .section--about-hero { padding: 16rem 0 4rem; min-height: 60vh; display: flex; align-items: center; }

  .section__inner {
    width: 100%;
    padding-left: var(--padding-x);
    padding-right: var(--padding-x);
  }

  .about-hero { grid-column: 3 / -1; }
  .about-hero__eyebrow { color: var(--brand-blue); margin-bottom: 2.4rem; }

  .about-block { grid-column: 3 / -1; }
  @media (min-width: 1200px) { .about-block { grid-column: 5 / span 9; } }

  .about-block > h2 { margin-bottom: 4rem; }
  .about-block > p + p { margin-top: 1.6rem; }
  .about-block__cta { margin-top: 3.2rem; }

  /* Process */
  .process {
    margin-top: 4rem;
    display: grid;
    gap: 2.4rem;
    counter-reset: process;
  }

  .process__item {
    border-top: 1px solid rgba(255, 253, 226, 0.18);
    padding-top: 1.6rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.8rem;
  }

  @media (min-width: 768px) {
    .process__item {
      grid-template-columns: 24rem 1fr;
      gap: 3.2rem;
    }
  }

  .process__num {
    color: var(--brand-blue);
  }

  /* Tools */
  .tools {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  @media (min-width: 768px) {
    .tools { grid-template-columns: repeat(4, 1fr); }
  }

  .tools__item {
    border: 1px solid rgba(255, 253, 226, 0.18);
    padding: 3.2rem 2rem;
    display: grid;
    place-items: center;
    transition: background-color var(--d-hover) var(--easeOutQuart);
  }

  .tools__item:hover {
    background: rgba(255, 253, 226, 0.04);
  }

  /* Off-hours */
  .off-hours {
    display: grid;
    gap: 3.2rem;
    grid-template-columns: 1fr;
    margin-top: 2.4rem;
  }

  @media (min-width: 768px) {
    .off-hours { grid-template-columns: 1fr 1fr; gap: 4.8rem; align-items: center; }
  }

  .off-hours__photo {
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, var(--brand-blue), var(--brand-dark-blue));
    border-radius: var(--r-sm);
    display: grid;
    place-items: center;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1.2rem;
    text-transform: uppercase;
  }
</style>
