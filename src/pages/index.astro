---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WhatWeDo from '../components/WhatWeDo.astro';
import Showcase from '../components/Showcase.astro';
import SectionIndicator from '../components/SectionIndicator.astro';
import Reveals from '../components/Reveals.astro';
import { u } from '../lib/url';

const projects = [
  { slug: 'power-pizza-counter',  name: 'Power Pizza Counter',     services: 'Design · Flutter · UI',     color: '#f4c81e', ratio: '16 / 11' },
  { slug: 'dany-resconi-libro',   name: 'Finalmente Gluten-free!', services: 'Branding · Editorial',       color: '#a4d65e', ratio: '4 / 5'   },
  { slug: 'dany-resconi-website', name: 'Dany Resconi Website',    services: 'Branding · Squarespace · SEO', color: '#3a86ff', ratio: '16 / 11' },
];

const sections = [
  { number: '01', name: 'Hero' },
  { number: '02', name: 'What I do' },
  { number: '03', name: 'Selected work' },
  { number: '04', name: 'Trusted me' },
  { number: '05', name: 'About' },
  { number: '06', name: 'Get in touch' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Federico de Servi',
  jobTitle: 'Designer, Brand-builder, Flutter Developer',
  url: 'https://federicodeservi.github.io/federicodeservi_website',
  address: { '@type': 'PostalAddress', addressLocality: 'Milano', addressCountry: 'IT' },
  email: 'federico@federicodeservi.com',
};
---

<BaseLayout
  title="Federico de Servi"
  description="Designer, brand-builder e flutter-dev a Milano. Lavoro con content creator italiani su siti, app e identità visive."
  jsonLd={jsonLd}
>
  <Reveals />
  <SectionIndicator sections={sections} />

  <Hero />
  <WhatWeDo />
  <Showcase projects={projects} />

  <!-- Trusted me -->
  <section class="trust" data-section data-section-name="Trusted me">
    <div class="trust__container container">
      <p class="trust__index t-italic-sm" data-reveal>04 — <em>They trusted me</em></p>
      <h2 class="trust__heading t-h2" data-reveal>
        <span>They trusted me</span><br />
        <span><em class="trust__heading-italic">to deliver</em>.</span>
      </h2>

      <div class="trust__quotes" data-reveal-stagger>
        <figure class="trust__quote" data-reveal-item>
          <blockquote>
            "Federico ha capito la voce di Power Pizza al primo briefing. L'app è piaciuta subito, ai conduttori e ai fan."
          </blockquote>
          <figcaption>— Cliente, Power Pizza Podcast</figcaption>
        </figure>
        <figure class="trust__quote" data-reveal-item>
          <blockquote>
            "Lavorare con Federico significa avere un punto di riferimento dal brand al delivery. Il libro è uscito esattamente come lo immaginavo."
          </blockquote>
          <figcaption>— Daniele Resconi, Creator</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- About brief -->
  <section class="about-brief" data-section data-section-name="About">
    <div class="about-brief__container container">
      <p class="about-brief__index t-italic-sm" data-reveal>05 — <em>About</em></p>
      <h2 class="about-brief__title" data-reveal>
        <span>Federico,</span>
        <span class="about-brief__title-italic">1995, Milano.</span>
      </h2>
      <p class="about-brief__desc" data-reveal>
        Faccio design, brand e (quando serve) sviluppo. Lavoro con creator italiani che hanno una voce e vogliono trasformarla in un prodotto fatto bene.
      </p>
      <p class="about-brief__cta" data-reveal>
        <a href={u('/about')} class="hover-line">→ Più su di me</a>
      </p>
    </div>
  </section>

  <!-- Get in touch -->
  <section class="contact-cta" data-section data-section-name="Get in touch">
    <div class="contact-cta__container container">
      <p class="contact-cta__index t-italic-sm" data-reveal>06 — <em>Get in touch</em></p>
      <h2 class="contact-cta__title" data-reveal>
        <span>Hai un progetto</span>
        <span>in mente?</span>
        <span class="contact-cta__title-italic">Parliamone.</span>
      </h2>
      <p class="contact-cta__cta" data-reveal>
        <a href={u('/contact')} class="btn">Scrivimi <span aria-hidden="true">→</span></a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* Trust */
  .trust {
    padding: 8rem 0 12rem;
  }

  .trust__index {
    color: var(--text-secondary);
    margin-bottom: 4rem;
  }
  .trust__index em { color: var(--brand-yellow); }

  .trust__heading {
    margin-bottom: 8rem;
    text-align: left;
    line-height: 0.9em;
  }
  .trust__heading-italic {
    font-family: var(--font-ivory);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
  }

  .trust__quotes {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media (min-width: 768px)  { .trust__quotes { grid-template-columns: 1fr 1fr; gap: 6.4rem; } }

  .trust__quote { margin: 0; }
  .trust__quote blockquote {
    font-family: var(--font-twk);
    font-weight: 400;
    font-size: 2rem;
    line-height: 1.4em;
    letter-spacing: -0.04rem;
    margin-bottom: 1.6rem;
  }
  @media (min-width: 1200px) {
    .trust__quote blockquote { font-size: 2.4rem; line-height: 1.3em; }
  }

  .trust__quote figcaption {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    text-transform: uppercase;
    color: var(--text-secondary);
    letter-spacing: 0.04em;
  }

  /* About brief */
  .about-brief {
    padding: 8rem 0 12rem;
    text-align: center;
    min-height: 60svh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-brief__container { max-width: 80rem; }

  .about-brief__index {
    color: var(--text-secondary);
    margin-bottom: 4rem;
  }
  .about-brief__index em { color: var(--brand-yellow); }

  .about-brief__title {
    font-family: var(--font-twk);
    font-weight: 600;
    line-height: 0.9em;
    letter-spacing: -0.096rem;
    text-transform: uppercase;
    font-size: 4rem;
    margin-bottom: 3.2rem;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px)  { .about-brief__title { font-size: 6.4rem; letter-spacing: -0.192rem; } }
  @media (min-width: 1200px) { .about-brief__title { font-size: 8rem; letter-spacing: -0.24rem; } }

  .about-brief__title-italic {
    font-family: var(--font-ivory);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
  }

  .about-brief__desc {
    font-family: var(--font-twk);
    font-size: 1.8rem;
    line-height: 1.4em;
    color: var(--text-secondary);
    max-width: 56ch;
    margin: 0 auto 3.2rem;
  }
  @media (min-width: 1200px) { .about-brief__desc { font-size: 2rem; } }

  /* Contact CTA */
  .contact-cta {
    padding: 12rem 0;
    text-align: center;
    background: var(--brand-yellow);
    color: var(--brand-dark-blue);
    min-height: 80svh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-cta__container { max-width: 100rem; }

  .contact-cta__index {
    color: rgba(5, 18, 54, 0.6);
    margin-bottom: 4rem;
  }
  .contact-cta__index em { color: var(--brand-dark-blue); }

  .contact-cta__title {
    font-family: var(--font-twk);
    font-weight: 600;
    line-height: 0.9em;
    letter-spacing: -0.12rem;
    text-transform: uppercase;
    font-size: 4.8rem;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px)  { .contact-cta__title { font-size: 8rem; letter-spacing: -0.24rem; } }
  @media (min-width: 1200px) { .contact-cta__title { font-size: 12rem; letter-spacing: -0.36rem; } }

  .contact-cta__title-italic {
    font-family: var(--font-ivory);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
  }

  .contact-cta .btn {
    background: var(--brand-dark-blue);
    color: var(--brand-yellow);
  }
</style>
