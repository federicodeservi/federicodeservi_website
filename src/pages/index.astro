---
import BaseLayout from '../layouts/BaseLayout.astro';
import WordsMorph from '../components/WordsMorph.astro';
import Marquee from '../components/Marquee.astro';
import CaseThumb from '../components/CaseThumb.astro';
import Reveals from '../components/Reveals.astro';
import { u } from '../lib/url';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Federico de Servi',
  jobTitle: 'Designer, Brand-builder, Flutter Developer',
  url: 'https://federicodeservi.github.io/federicodeservi_website',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Milano',
    addressCountry: 'IT',
  },
  email: 'federico@federicodeservi.com',
};

const heroWords = ['designer', 'brand-builder', 'flutter-dev', 'editor', 'fan dei podcast'];
---

<BaseLayout
  title="Federico de Servi"
  description="Designer, brand-builder e flutter-dev a Milano. Lavoro con content creator italiani su siti, app e identità visive."
  jsonLd={jsonLd}
>
  <Reveals />

  <!-- ===== 01 HERO ===== -->
  <section class="hero" aria-labelledby="hero-h1">
    <div class="hero-mega-num" aria-hidden="true">01</div>

    <div class="hero-meta-top">
      <div>Index <strong>01 / 06</strong></div>
      <div>Latest <strong>Power Pizza Counter, 2024</strong></div>
      <div>Based in <strong>Milano, IT</strong></div>
      <div>Working <strong>Remote, mostly</strong></div>
    </div>

    <div class="hero-headline-block">
      <h1 id="hero-h1" class="hero-headline">
        <span class="line"><span class="inner">Sono un</span></span>
        <span class="line indent"><span class="inner"><em><WordsMorph words={heroWords} /></em></span></span>
        <span class="line"><span class="inner">per content</span></span>
        <span class="line right"><span class="inner">creator italiani.</span></span>
      </h1>
    </div>

    <div class="hero-bottom">
      <div class="scroll-hint">scroll · esplora</div>
      <div class="sub">
        Design, brand, sviluppo. A volte tutte e tre nello stesso progetto.
        <small>since 2020</small>
      </div>
      <div class="right-meta">
        <div>Selected work / <strong>03</strong></div>
        <div>Brands / <strong>Power Pizza, Daniele Resconi, +</strong></div>
      </div>
    </div>
  </section>

  <!-- ===== 02 WHAT I DO ===== -->
  <section class="v5-section creme">
    <div class="section-mega-num" aria-hidden="true">02</div>

    <div class="label-row">
      <span class="num">02</span>
      <span class="dot"></span>
      <span>What I do</span>
      <span class="dot"></span>
      <span>Three things</span>
    </div>

    <h2 class="what-mega-h" data-reveal>
      Tre cose,<br />
      <span class="l2">fatte spesso</span><br />
      <span class="l3">insieme.</span>
    </h2>

    <div class="what-grid" data-reveal-group>
      <div class="cluster" data-reveal-item>
        <div class="num">02.1 / <strong>Design</strong></div>
        <h3>Siti, app, identità visive</h3>
        <p>Per chi vuole un prodotto che si distingue, non l'ennesimo template. Lavoro stretto sul concept e sulla cura dei dettagli.</p>
        <ul>
          <li>Web design</li>
          <li>UI / UX</li>
          <li>Prototyping</li>
        </ul>
      </div>
      <div class="cluster" data-reveal-item>
        <div class="num">02.2 / <strong>Brand</strong></div>
        <h3>Identità per chi parla a un pubblico</h3>
        <p>Voce, sistema, applicazioni. Pensato per content creator che hanno già una comunità da onorare.</p>
        <ul>
          <li>Brand identity</li>
          <li>Editorial / libri</li>
          <li>Visual systems</li>
        </ul>
      </div>
      <div class="cluster" data-reveal-item>
        <div class="num">02.3 / <strong>Sviluppo</strong></div>
        <h3>Quando il design ha bisogno di esistere davvero</h3>
        <p>Flutter per app mobile, codice quando serve. Non sono un dev generalista — costruisco quello che ho disegnato.</p>
        <ul>
          <li>App mobile (Flutter)</li>
          <li>Squarespace dev</li>
          <li>Custom web (light)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== 03 SELECTED WORK ===== -->
  <section class="v5-section" id="work">
    <div class="section-mega-num" aria-hidden="true">03</div>

    <div class="label-row">
      <span class="num">03</span>
      <span class="dot"></span>
      <span>Selected work</span>
      <span class="dot"></span>
      <span>2023 — 2025</span>
    </div>

    <h2 class="work-h" data-reveal>
      Selected <em>work,</em><br />
      not all of it.
      <small>Three projects below. More on Behance.</small>
    </h2>

    <article class="case" data-reveal-group>
      <div class="case-thumb-wrap" data-reveal-item>
        <CaseThumb
          href={u('/work/power-pizza-counter')}
          title="Power Pizza Counter"
          ratio="4 / 5"
          caption="PWR-PIZZA · 2024"
        />
      </div>
      <div class="case-info" data-reveal-item>
        <div class="case-num-big">/01</div>
        <dl class="case-meta">
          <dt>Cliente</dt><dd>Power Pizza</dd>
          <dt>Ruolo</dt><dd>Design + Flutter</dd>
          <dt>Anno</dt><dd>2024</dd>
          <dt>Result</dt><dd>5k+ download · 500+ ★★★★★</dd>
        </dl>
        <h3>Power Pizza<br />Counter.</h3>
        <p>Un'app per contare le pizze del podcast. Si dice anche per intercettare uno dei rituali più amati dai fan.</p>
        <a href={u('/work/power-pizza-counter')} class="case-arrow">Apri progetto →</a>
      </div>
    </article>

    <article class="case case--reverse" data-reveal-group>
      <div class="case-info" data-reveal-item>
        <div class="case-num-big">/02</div>
        <dl class="case-meta">
          <dt>Cliente</dt><dd>Daniele Resconi</dd>
          <dt>Ruolo</dt><dd>Identità + Editorial</dd>
          <dt>Anno</dt><dd>2023</dd>
          <dt>Result</dt><dd>Pubblicato · ottime vendite</dd>
        </dl>
        <h3>Finalmente<br />Gluten-free!</h3>
        <p>Identità + design del libro per il primo manuale gluten-free di Dany Resconi. Gestito anche l'iter con l'editore.</p>
        <a href={u('/work/dany-resconi-libro')} class="case-arrow">Apri progetto →</a>
      </div>
      <div class="case-thumb-wrap" data-reveal-item>
        <CaseThumb
          href={u('/work/dany-resconi-libro')}
          title="Finalmente Gluten-free!"
          ratio="4 / 5"
          caption="D-RESCONI · 2023"
        />
      </div>
    </article>

    <article class="case" data-reveal-group>
      <div class="case-thumb-wrap" data-reveal-item>
        <CaseThumb
          href={u('/work/dany-resconi-website')}
          title="Dany Resconi Website"
          ratio="4 / 5"
          caption="D-RESCONI · 2023"
        />
      </div>
      <div class="case-info" data-reveal-item>
        <div class="case-num-big">/03</div>
        <dl class="case-meta">
          <dt>Cliente</dt><dd>Daniele Resconi</dd>
          <dt>Ruolo</dt><dd>Branding + Squarespace</dd>
          <dt>Anno</dt><dd>2023</dd>
          <dt>Result</dt><dd>Sito live · ranking SEO ottimo</dd>
        </dl>
        <h3>Dany Resconi<br />Website.</h3>
        <p>Sito completo per il primo creator italiano specializzato in gluten-free. Brand + dev + SEO on-page.</p>
        <a href={u('/work/dany-resconi-website')} class="case-arrow">Apri progetto →</a>
      </div>
    </article>

    <div class="work-footer-link">
      <a href="https://www.behance.net/federicodeservi" target="_blank" rel="noopener noreferrer" class="case-arrow">See all work · Behance ↗</a>
    </div>
  </section>

  <!-- ===== 04 TRUST ===== -->
  <section class="v5-section dark">
    <div class="section-mega-num" aria-hidden="true">04</div>

    <div class="label-row">
      <span class="num">04</span>
      <span class="dot"></span>
      <span>They trusted me</span>
      <span class="dot"></span>
      <span>Selected clients &amp; quotes</span>
    </div>

    <h2 class="trust-h" data-reveal>
      Hanno scelto<br />
      di lavorare <em>con me</em>.
    </h2>

    <Marquee
      items={[
        { label: 'Power Pizza' },
        { label: 'Daniele Resconi' },
        { label: 'Smart Roadways' },
        { label: 'Klimu' },
        { label: '+ altri' },
      ]}
    />

    <div class="testimonials" data-reveal-group>
      <figure class="testimonial" data-reveal-item>
        <blockquote>"Federico ha capito la voce di Power Pizza al primo briefing. L'app è piaciuta subito, ai conduttori e ai fan."</blockquote>
        <figcaption>— Cliente, Power Pizza</figcaption>
      </figure>
      <figure class="testimonial" data-reveal-item>
        <blockquote>"Lavorare con Federico significa avere un punto di riferimento dal brand al delivery. Il libro è uscito esattamente come lo immaginavo."</blockquote>
        <figcaption>— Daniele Resconi, Creator</figcaption>
      </figure>
    </div>
  </section>

  <!-- ===== 05 ABOUT ===== -->
  <section class="v5-section">
    <div class="section-mega-num" aria-hidden="true">05</div>

    <div class="label-row">
      <span class="num">05</span>
      <span class="dot"></span>
      <span>About</span>
      <span class="dot"></span>
      <span>Federico de Servi, 1995</span>
    </div>

    <div class="about-grid" data-reveal-group>
      <div class="portrait" data-reveal-item aria-hidden="true"></div>
      <div class="about-text" data-reveal-item>
        <h2>
          Federico<br />
          de Servi,<br />
          <em>1995, Milano.</em>
        </h2>
        <p>Ho iniziato facendo siti per amici, poi per amici di amici. Adesso lavoro con creator italiani che vogliono un prodotto — sito, app, libro — fatto bene.</p>
        <p>Mi interessa il punto in cui design, codice e voce si incontrano. Spesso lavoro su tutti e tre.</p>
        <a href={u('/about')} class="case-arrow">Più su di me →</a>
      </div>
    </div>
  </section>

  <!-- ===== 06 CONTACT ===== -->
  <section class="v5-section dark contact-final" id="contact">
    <div class="section-mega-num" aria-hidden="true">06</div>

    <div class="label-row centered">
      <span class="num">06</span>
      <span class="dot"></span>
      <span>Get in touch</span>
    </div>

    <h2 class="contact-h" data-reveal>
      Hai un progetto<br />
      <em>in mente?</em><br />
      Parliamone.
    </h2>

    <a href="mailto:federico@federicodeservi.com" class="btn" data-cursor="scrivimi" data-reveal>
      Scrivimi <span class="arr" aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>

<style>
  /* ===== HERO 01 ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    max-height: 1200px;
    padding: 11rem var(--pad) 5.6rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 4.8rem;
    background: var(--aurora);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 30%, rgba(255, 45, 157, 0.35) 0%, transparent 45%),
      radial-gradient(ellipse at 80% 70%, rgba(0, 240, 255, 0.30) 0%, transparent 45%),
      repeating-linear-gradient(135deg, transparent 0 12px, rgba(255, 45, 157, 0.04) 12px 13px);
    pointer-events: none;
    z-index: 1;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at center, rgba(0, 240, 255, 0.5) 1px, transparent 1.5px);
    background-size: 14px 14px;
    background-position: 0 0;
    opacity: 0.15;
    mix-blend-mode: screen;
    pointer-events: none;
    z-index: 1;
    transform: skewY(-8deg);
    -webkit-mask: linear-gradient(135deg, transparent 0%, black 30%, black 60%, transparent 100%);
            mask: linear-gradient(135deg, transparent 0%, black 30%, black 60%, transparent 100%);
  }

  .hero-mega-num {
    position: absolute;
    bottom: -8vw;
    right: -2vw;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 42vw;
    line-height: 0.78;
    color: var(--accent-warm);
    opacity: 0.06;
    pointer-events: none;
    letter-spacing: -0.05em;
    z-index: 0;
    text-shadow: -3px 0 var(--accent-cool), 3px 0 var(--accent-warm);
  }

  .hero-meta-top {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3.2rem;
    font-family: var(--font-mono);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    padding-bottom: 1.6rem;
    border-bottom: 1px solid var(--rule);
    z-index: 2;
    position: relative;
  }
  .hero-meta-top div strong {
    display: block;
    color: var(--ink);
    font-weight: 500;
    font-size: 1.2rem;
    margin-top: 0.4rem;
  }

  .hero-headline-block {
    z-index: 2;
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    padding: 4rem 0;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(80px, 13.5vw, 220px);
    line-height: 0.86;
    letter-spacing: -0.045em;
    text-wrap: balance;
    color: var(--ink);
    width: 100%;
    text-shadow:
      -2px 0 rgba(255, 45, 157, 0.7),
      2px 0 rgba(0, 240, 255, 0.7);
  }

  .hero-headline .line {
    display: block;
    overflow: hidden;
  }
  .hero-headline .line .inner { display: inline-block; }
  .hero-headline .line.indent { padding-left: 12vw; }
  .hero-headline .line.right { text-align: right; }

  .hero-headline em {
    font-style: normal;
    color: var(--accent-cool);
    font-family: var(--font-display);
    font-weight: 800;
    display: inline-block;
    position: relative;
    text-shadow:
      0 0 24px rgba(0, 240, 255, 0.7),
      -2px 0 rgba(255, 45, 157, 0.8),
      2px 0 rgba(197, 240, 46, 0.6);
  }

  .hero-bottom {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: end;
    gap: 3.2rem;
    padding-top: 2.8rem;
    border-top: 1px solid var(--rule);
    z-index: 2;
    position: relative;
  }
  .hero-bottom .scroll-hint {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .hero-bottom .scroll-hint::before {
    content: '';
    width: 2.4rem;
    height: 1px;
    background: var(--ink-faint);
  }
  .hero-bottom .sub {
    text-align: center;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--ink);
    max-width: 36rem;
    line-height: 1.4;
    text-wrap: pretty;
    margin: 0 auto;
  }
  .hero-bottom .sub small {
    display: block;
    color: var(--ink-faint);
    font-weight: 400;
    font-size: 1.3rem;
    margin-top: 0.4rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .hero-bottom .right-meta {
    text-align: right;
    font-family: var(--font-mono);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }
  .hero-bottom .right-meta strong { color: var(--ink); font-weight: 500; }

  /* ===== SECTION GENERIC ===== */
  .v5-section {
    position: relative;
    padding: 22rem var(--pad);
    overflow: hidden;
  }
  .v5-section.dark { background: var(--bg-deep); }
  .v5-section.creme { background: var(--bg-creme); }

  .section-mega-num {
    position: absolute;
    top: 50%;
    left: -2vw;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 56vw;
    line-height: 0.78;
    color: var(--accent-warm);
    opacity: 0.04;
    pointer-events: none;
    letter-spacing: -0.05em;
    z-index: 0;
    text-shadow: -4px 0 var(--accent-cool), 4px 0 var(--accent-warm);
  }
  .v5-section.dark .section-mega-num { color: var(--accent-cool); opacity: 0.06; }

  .label-row {
    display: flex;
    align-items: baseline;
    gap: 1.2rem;
    font-family: var(--font-mono);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
    margin-bottom: 9.6rem;
    padding-bottom: 1.4rem;
    border-bottom: 1px solid var(--rule);
    position: relative;
    z-index: 2;
  }
  .label-row.centered {
    justify-content: center;
    margin-bottom: 8rem;
    border: none;
    padding: 0;
  }
  .label-row .num { color: var(--accent-cool); font-weight: 500; font-size: 1.2rem; }
  .label-row .dot { width: 4px; height: 4px; background: var(--accent-warm); border-radius: 50%; }

  /* ===== 02 WHAT I DO ===== */
  .what-mega-h {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(60px, 9vw, 150px);
    line-height: 0.88;
    letter-spacing: -0.035em;
    margin-bottom: 14rem;
    text-wrap: balance;
    position: relative;
    z-index: 2;
    color: var(--ink);
  }
  .what-mega-h .l2 { padding-left: 16vw; color: var(--accent-warm); display: inline-block; }
  .what-mega-h .l3 { padding-left: 6vw; color: var(--accent-cool); display: inline-block; }

  .what-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule);
    position: relative;
    z-index: 2;
  }
  .cluster {
    padding: 4.8rem 3.2rem 4.8rem 0;
    border-right: 1px solid var(--rule);
  }
  .cluster:last-child { border-right: none; padding-right: 0; }
  .cluster:not(:first-child) { padding-left: 3.2rem; }

  .cluster .num {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    margin-bottom: 3.6rem;
  }
  .cluster .num strong { color: var(--accent-cool); font-weight: 500; }

  .cluster h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 3.2rem;
    line-height: 1.05;
    letter-spacing: -0.018em;
    margin-bottom: 3.2rem;
    text-wrap: pretty;
    color: var(--ink);
  }
  .cluster p {
    font-size: 1.5rem;
    color: var(--ink-muted);
    line-height: 1.55;
    margin-bottom: 4.8rem;
  }
  .cluster ul li {
    padding: 1rem 0;
    border-top: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    justify-content: space-between;
    color: var(--ink);
  }
  .cluster ul li::after {
    content: '↗';
    color: var(--ink-faint);
    font-family: var(--font-body);
    font-size: 1.4rem;
  }
  .cluster ul li:last-child { border-bottom: 1px solid var(--rule); }

  /* ===== 03 WORK ===== */
  .work-h {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(60px, 11vw, 180px);
    line-height: 0.85;
    letter-spacing: -0.04em;
    margin-bottom: 16rem;
    position: relative;
    z-index: 2;
    text-wrap: balance;
    color: var(--ink);
  }
  .work-h em {
    font-style: normal;
    color: var(--accent-warm);
    text-shadow: 0 0 20px rgba(255, 45, 157, 0.5);
  }
  .work-h small {
    display: block;
    font-family: var(--font-mono);
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    margin-top: 3.2rem;
    font-weight: 400;
  }

  .case {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 9.6rem;
    margin-bottom: 20rem;
    position: relative;
    z-index: 2;
    align-items: center;
  }

  .case-info {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 4rem 0;
    gap: 3.2rem;
  }

  .case-num-big {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14vw;
    line-height: 0.85;
    letter-spacing: -0.05em;
    color: var(--ink-faint);
    margin-bottom: 3.2rem;
    opacity: 0.4;
  }

  .case-meta {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1rem 1.6rem;
    margin-bottom: 3.2rem;
    border-top: 1px solid var(--rule);
    padding-top: 2rem;
  }
  .case-meta dt { color: var(--ink-faint); margin: 0; }
  .case-meta dd { color: var(--ink); font-weight: 500; margin: 0; }

  .case-info h3 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(36px, 4.2vw, 64px);
    line-height: 0.95;
    letter-spacing: -0.025em;
    margin-bottom: 2.4rem;
    text-wrap: pretty;
    color: var(--ink);
  }
  .case-info p {
    font-size: 1.7rem;
    color: var(--ink-muted);
    line-height: 1.5;
    margin-bottom: 3.2rem;
    max-width: 48rem;
    text-wrap: pretty;
  }

  .case-arrow {
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
