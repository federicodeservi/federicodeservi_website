---
export interface Props {
  number: string;
  label?: string;
}
const { number, label } = Astro.props;
---

<div class="sec-num" aria-hidden="true">
  <span class="sec-num__digit">{number}</span>
  {label && <span class="sec-num__label">{label}</span>}
</div>

<style>
  .sec-num {
    position: sticky;
    top: 50%;
    transform: translateY(-50%);
    grid-column: 1 / span 2;
    pointer-events: none;
    user-select: none;
    align-self: start;
    z-index: 0;
  }

  .sec-num__digit {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(120px, 18vw, 320px);
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--brand-yellow);
    opacity: 0.95;
  }

  .section--invert .sec-num__digit {
    color: var(--brand-dark-blue);
  }

  .sec-num__label {
    display: block;
    margin-top: 0.8rem;
    font-family: var(--font-mono);
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: -0.028rem;
    opacity: 0.6;
  }

  @media (max-width: 767px) {
    .sec-num {
      position: static;
      transform: none;
    }
    .sec-num__digit {
      font-size: clamp(80px, 28vw, 160px);
    }
  }
</style>
