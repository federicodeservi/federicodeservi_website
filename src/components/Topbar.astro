---
// v5 Y2K Glitch fixed top bar: name on the left, year/place center, nav right.
import { u } from '../lib/url';
const year = new Date().getFullYear();
---

<div class="topbar">
  <div class="topbar__left">
    <a class="topbar__name" href={u('/')}>Federico de Servi</a>
    <span class="topbar__tag">— independent design studio (of one)</span>
  </div>
  <div class="topbar__center"><strong>{year}</strong> — Milano, IT</div>
  <nav class="topbar__right" aria-label="Primary">
    <a href={u('/work')} class="nav-link">Work</a>
    <a href={u('/about')} class="nav-link">About</a>
    <a href={u('/contact')} class="nav-link">Contact</a>
  </nav>
</div>

<style>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 2.4rem var(--pad);
    background: rgba(10, 5, 36, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 45, 157, 0.25);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink);
  }

  .topbar__left {
    display: flex;
    gap: 2.4rem;
    align-items: baseline;
  }

  .topbar__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: -0.005em;
    text-transform: none;
    color: var(--ink);
  }

  .topbar__tag {
    color: var(--ink-faint);
  }

  .topbar__center {
    color: var(--ink-faint);
    justify-self: center;
  }

  .topbar__center strong {
    color: var(--ink);
    font-weight: 500;
  }

  .topbar__right {
    display: flex;
    gap: 2.8rem;
    justify-self: end;
  }

  .topbar__right a {
    color: var(--ink);
    transition: color 200ms;
  }

  .topbar__right a:hover {
    color: var(--accent-warm);
  }

  @media (max-width: 900px) {
    .topbar { padding: 1.6rem var(--pad); font-size: 1.2rem; }
    .topbar__center,
    .topbar__tag { display: none; }
    .topbar__right { gap: 2rem; }
  }
</style>
