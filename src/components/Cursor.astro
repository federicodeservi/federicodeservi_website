---
// v5 Y2K Glitch cursor — dot + label, lerp trail, hidden ≤ 900px.
---

<div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>
<div class="cursor-label" id="cursor-label" aria-hidden="true"></div>

<style>
  .cursor-dot {
    position: fixed;
    top: 0;
    left: 0;
    width: 8px;
    height: 8px;
    background: var(--ink);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition:
      width 250ms var(--easing-settle),
      height 250ms var(--easing-settle),
      background 200ms;
    mix-blend-mode: difference;
    opacity: 0;
    will-change: transform;
  }
  .cursor-dot.is-visible { opacity: 1; }
  .cursor-dot.hover-link {
    width: 40px;
    height: 40px;
    background: var(--accent-warm);
    mix-blend-mode: normal;
  }
  .cursor-dot.hover-image {
    width: 100px;
    height: 100px;
    background: var(--accent-warm);
    mix-blend-mode: normal;
  }

  .cursor-label {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 10000;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--bg);
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 200ms;
    white-space: nowrap;
  }
  .cursor-label.show { opacity: 1; }
</style>

<script>
  import { reducedMotion, isDesktop } from '../lib/motion';

  let raf = 0;
  let cleanup: (() => void) | null = null;

  const setup = () => {
    if (cleanup) {
      cleanup();
      cleanup = null;
    }

    const dot = document.getElementById('cursor-dot');
    const label = document.getElementById('cursor-label');
    if (!dot || !label) return;

    if (reducedMotion() || !isDesktop()) {
      dot.style.display = 'none';
      label.style.display = 'none';
      return;
    }
    dot.style.display = '';
    label.style.display = '';

    let mx = window.innerWidth / 2;
    let my = window.innerHeight / 2;
    let cx = mx;
    let cy = my;

    const onMove = (e: MouseEvent) => {
      mx = e.clientX;
      my = e.clientY;
      dot.classList.add('is-visible');
    };
    const onLeave = () => dot.classList.remove('is-visible');

    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseleave', onLeave);

    const tick = () => {
      cx += (mx - cx) * 0.25;
      cy += (my - cy) * 0.25;
      dot.style.transform = `translate(${cx}px, ${cy}px) translate(-50%, -50%)`;
      label.style.transform = `translate(${cx + 24}px, ${cy + 24}px)`;
      raf = requestAnimationFrame(tick);
    };
    tick();

    const linkSel = 'a, button, .case-thumb, .logo-pill, .nav-link';
    const linkEls = document.querySelectorAll<HTMLElement>(linkSel);
    const onLinkEnter = () => dot.classList.add('hover-link');
    const onLinkLeave = () => dot.classList.remove('hover-link');
    linkEls.forEach((el) => {
      el.addEventListener('mouseenter', onLinkEnter);
      el.addEventListener('mouseleave', onLinkLeave);
    });

    const cursorEls = document.querySelectorAll<HTMLElement>('[data-cursor]');
    const onImgEnter = (e: Event) => {
      const t = e.currentTarget as HTMLElement;
      const kind = t.dataset.cursor || '';
      if (kind === 'link' || kind === '') {
        dot.classList.add('hover-link');
        return;
      }
      dot.classList.add('hover-image');
      label.textContent = kind;
      label.classList.add('show');
    };
    const onImgLeave = () => {
      dot.classList.remove('hover-image', 'hover-link');
      label.classList.remove('show');
    };
    cursorEls.forEach((el) => {
      el.addEventListener('mouseenter', onImgEnter);
      el.addEventListener('mouseleave', onImgLeave);
    });

    cleanup = () => {
      cancelAnimationFrame(raf);
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseleave', onLeave);
      linkEls.forEach((el) => {
        el.removeEventListener('mouseenter', onLinkEnter);
        el.removeEventListener('mouseleave', onLinkLeave);
      });
      cursorEls.forEach((el) => {
        el.removeEventListener('mouseenter', onImgEnter);
        el.removeEventListener('mouseleave', onImgLeave);
      });
    };
  };

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
