---
// Custom cursor — mix-blend-difference, lerp trail, off below 901px.
---

<div class="cursor" aria-hidden="true"></div>

<style>
  .cursor {
    --mouse-x: 0px;
    --mouse-y: 0px;
    position: fixed;
    left: 0;
    top: 0;
    transform: translate3d(calc(var(--mouse-x) - 50%), calc(var(--mouse-y) - 50%), 0);
    pointer-events: none;
    mix-blend-mode: difference;
    background: var(--brand-yellow);
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    transition: width var(--d-hover) var(--easeOutQuart),
                height var(--d-hover) var(--easeOutQuart),
                opacity var(--d-hover) var(--easeOutQuart);
    z-index: 9999;
    opacity: 0;
    will-change: transform, width, height;
  }

  .cursor.is-visible { opacity: 1; }
  .cursor--hover-link { width: 4rem; height: 4rem; }
  .cursor--hover-image { width: 8rem; height: 8rem; }
</style>

<script>
  import { reducedMotion, isDesktop } from '../lib/motion';

  let raf = 0;
  let cleanup: (() => void) | null = null;

  const setup = () => {
    if (cleanup) {
      cleanup();
      cleanup = null;
    }

    const cursor = document.querySelector<HTMLElement>('.cursor');
    if (!cursor) return;
    if (reducedMotion() || !isDesktop()) {
      cursor.style.display = 'none';
      return;
    }
    cursor.style.display = '';

    let mx = window.innerWidth / 2;
    let my = window.innerHeight / 2;
    let cx = mx;
    let cy = my;

    const onMove = (e: MouseEvent) => {
      mx = e.clientX;
      my = e.clientY;
      cursor.classList.add('is-visible');
    };

    const onLeave = () => cursor.classList.remove('is-visible');

    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseleave', onLeave);

    const tick = () => {
      cx += (mx - cx) * 0.18;
      cy += (my - cy) * 0.18;
      cursor.style.setProperty('--mouse-x', `${cx}px`);
      cursor.style.setProperty('--mouse-y', `${cy}px`);
      raf = requestAnimationFrame(tick);
    };
    tick();

    const onEnter = (e: Event) => {
      const t = e.currentTarget as HTMLElement;
      const kind = t.dataset.cursor;
      cursor.classList.remove('cursor--hover-link', 'cursor--hover-image');
      if (kind === 'link') cursor.classList.add('cursor--hover-link');
      if (kind === 'image') cursor.classList.add('cursor--hover-image');
    };
    const onLeaveEl = () => {
      cursor.classList.remove('cursor--hover-link', 'cursor--hover-image');
    };

    const targets = document.querySelectorAll<HTMLElement>('[data-cursor]');
    targets.forEach((el) => {
      el.addEventListener('mouseenter', onEnter);
      el.addEventListener('mouseleave', onLeaveEl);
    });

    // Auto-attach link state to interactive elements
    const interactive = document.querySelectorAll<HTMLElement>(
      'a:not([data-cursor]), button:not([data-cursor])',
    );
    interactive.forEach((el) => {
      el.addEventListener('mouseenter', () => cursor.classList.add('cursor--hover-link'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('cursor--hover-link'));
    });

    cleanup = () => {
      cancelAnimationFrame(raf);
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseleave', onLeave);
      targets.forEach((el) => {
        el.removeEventListener('mouseenter', onEnter);
        el.removeEventListener('mouseleave', onLeaveEl);
      });
    };
  };

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
