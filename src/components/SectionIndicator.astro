---
export interface Props {
  sections: { number: string; name: string }[];
}
const { sections } = Astro.props;
---

<aside class="sec-ind" data-sec-ind aria-hidden="true">
  <div class="sec-ind__indexes">
    {sections.map((s, i) => (
      <span class="sec-ind__index" data-idx={i}>{s.number}</span>
    ))}
  </div>
  <div class="sec-ind__line"></div>
  <div class="sec-ind__names">
    {sections.map((s, i) => (
      <span class="sec-ind__name" data-idx={i}>{s.name}</span>
    ))}
  </div>
</aside>

<style>
  .sec-ind {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: calc(50svh + 16.2rem + 4.4rem);
    padding-left: var(--padding-x);
    padding-bottom: 20.6rem;
    pointer-events: none;
    grid-template-columns: repeat(var(--columns), 1fr);
    gap: var(--gap-x);
    font-family: var(--font-herbik);
    font-size: 1.2rem;
    font-weight: 500;
    font-style: italic;
    line-height: 1;
    z-index: 20;
    mix-blend-mode: difference;
    color: var(--brand-yellow);
    transition: opacity var(--d-micro) var(--easeOutQuart);
  }

  @media (min-width: 1200px) { .sec-ind { display: grid; } }

  .sec-ind__indexes,
  .sec-ind__names {
    grid-column: span 2;
    align-self: end;
    height: 1.4rem;
    overflow: hidden;
    position: relative;
  }

  .sec-ind__indexes {
    grid-column: 1 / span 1;
    text-align: right;
  }

  .sec-ind__names {
    grid-column: 2 / span 2;
  }

  .sec-ind__line {
    grid-column: span 1;
    align-self: end;
    width: 2rem;
    height: 0.1rem;
    background-color: var(--brand-yellow);
    margin: 0 1.2rem;
    transform: translateY(-0.6rem);
  }

  .sec-ind__index,
  .sec-ind__name {
    display: block;
    height: 1.4rem;
    line-height: 1.4rem;
    transform: translateY(calc((var(--current, 0)) * -100%));
    transition: transform 0.6s var(--easeOutQuart);
    will-change: transform;
  }

  .sec-ind.is-hidden { opacity: 0; }
</style>

<script>
  const setup = () => {
    const ind = document.querySelector<HTMLElement>('[data-sec-ind]');
    if (!ind) return;

    const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-section]'));
    if (!sections.length) return;

    const indexes = ind.querySelectorAll<HTMLElement>('.sec-ind__index');
    const names = ind.querySelectorAll<HTMLElement>('.sec-ind__name');

    let current = 0;

    const onScroll = () => {
      const center = window.scrollY + window.innerHeight / 2;
      let idx = 0;
      sections.forEach((s, i) => {
        const top = s.offsetTop;
        if (center >= top) idx = i;
      });
      if (idx !== current) {
        current = idx;
        indexes.forEach((el) => el.style.setProperty('--current', String(idx)));
        names.forEach((el) => el.style.setProperty('--current', String(idx)));
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  };

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
