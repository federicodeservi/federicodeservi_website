---
// Words morph using opacity + blur crossfade — the fromanother signature.
// Words stack via grid, only the active one is fully visible.
export interface Props {
  words: string[];
  italicIdx?: number[];
  interval?: number; // ms between swaps
}
const { words, italicIdx = [], interval = 2400 } = Astro.props;
---

<span class="words" data-words-morph data-interval={interval}>
  {words.map((w, i) => (
    <span
      class={`words__word${italicIdx.includes(i) ? ' words__word--italic' : ''}${i === 0 ? ' is-active' : ''}`}
      data-word-idx={i}
    >
      {w}
    </span>
  ))}
</span>

<style>
  .words {
    display: inline-grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    vertical-align: baseline;
  }

  .words > * {
    grid-column: 1 / -1;
    grid-row: 1 / -1;
  }

  .words__word {
    white-space: nowrap;
    text-wrap: nowrap;
    word-wrap: nowrap;
    opacity: 0;
    filter: blur(10px);
    transition:
      opacity var(--d-reveal) var(--easeOutQuart),
      filter var(--d-reveal) var(--easeOutQuart);
    will-change: opacity, filter;
    color: var(--brand-blue);
  }

  .words__word.is-active {
    opacity: 1;
    filter: blur(0);
  }

  .words__word--italic {
    font-family: var(--font-ivory);
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
  }
</style>

<script>
  import { reducedMotion } from '../lib/motion';

  const setup = () => {
    document.querySelectorAll<HTMLElement>('[data-words-morph]').forEach((wrap) => {
      const words = Array.from(wrap.querySelectorAll<HTMLElement>('.words__word'));
      if (words.length < 2) return;

      const interval = parseInt(wrap.dataset.interval || '2400', 10);
      let idx = 0;

      const tick = () => {
        const prev = words[idx]!;
        idx = (idx + 1) % words.length;
        const next = words[idx]!;
        prev.classList.remove('is-active');
        next.classList.add('is-active');
      };

      if (reducedMotion()) return;

      // Wait for the page loader to finish before starting
      const start = () => {
        setInterval(tick, interval);
      };

      if (sessionStorage.getItem('fds-loader-shown') === '1') {
        start();
      } else {
        setTimeout(start, 2400);
      }
    });
  };

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
