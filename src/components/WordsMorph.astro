---
// v5 Y2K Glitch — letter-by-letter morph cycling through words.
// Letters fade up + rotate in, fade up + rotate out.
export interface Props {
  words: string[];
}
const { words } = Astro.props;
const initial = words[0] ?? '';
---

<span class="morph-wrap" data-morph data-words={JSON.stringify(words)}>
  {[...initial].map((ch) => (
    <span class="morph-letter">{ch === ' ' ? ' ' : ch}</span>
  ))}
</span>

<style>
  .morph-wrap {
    display: inline-block;
    position: relative;
    vertical-align: baseline;
    line-height: 0.86;
  }

  .morph-letter {
    display: inline-block;
    animation: letterIn 600ms var(--easing-edit) both;
    will-change: transform, opacity;
  }

  .morph-letter.out {
    animation: letterOut 400ms var(--easing-edit) both;
  }

  @keyframes letterIn {
    from { opacity: 0; transform: translateY(40%) rotate(6deg); }
    to   { opacity: 1; transform: translateY(0) rotate(0); }
  }

  @keyframes letterOut {
    from { opacity: 1; transform: translateY(0) rotate(0); }
    to   { opacity: 0; transform: translateY(-40%) rotate(-6deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .morph-letter,
    .morph-letter.out { animation: none; }
  }
</style>

<script>
  const setup = () => {
    document.querySelectorAll<HTMLElement>('[data-morph]').forEach((wrap) => {
      const raw = wrap.dataset.words || '[]';
      let words: string[] = [];
      try { words = JSON.parse(raw); } catch { return; }
      if (!words.length) return;

      let idx = 0;

      const renderWord = (word: string) => {
        wrap.innerHTML = '';
        [...word].forEach((ch, i) => {
          const span = document.createElement('span');
          span.className = 'morph-letter';
          span.textContent = ch === ' ' ? ' ' : ch;
          span.style.animationDelay = `${i * 30}ms`;
          wrap.appendChild(span);
        });
      };

      const swap = () => {
        const letters = wrap.querySelectorAll<HTMLElement>('.morph-letter');
        letters.forEach((l, i) => {
          l.classList.add('out');
          l.style.animationDelay = `${i * 25}ms`;
        });
        setTimeout(() => {
          idx = (idx + 1) % words.length;
          renderWord(words[idx]!);
        }, 500);
      };

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return; // keep static initial word

      // Replace initial server-rendered letters with managed render so
      // the first cycle is identical to subsequent ones.
      renderWord(words[0]!);
      const handle = window.setInterval(swap, 2800);
      // Store handle for cleanup on Astro view-transitions
      (wrap as HTMLElement & { _morphHandle?: number })._morphHandle = handle;
    });
  };

  const teardown = () => {
    document.querySelectorAll<HTMLElement>('[data-morph]').forEach((wrap) => {
      const w = wrap as HTMLElement & { _morphHandle?: number };
      if (w._morphHandle) {
        clearInterval(w._morphHandle);
        w._morphHandle = undefined;
      }
    });
  };

  setup();
  document.addEventListener('astro:before-swap', teardown);
  document.addEventListener('astro:after-swap', setup);
</script>
