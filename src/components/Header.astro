---
// Fixed header: hamburger left, logo center, contact right.
// mix-blend-mode: difference inverts against any background.
import { u } from '../lib/url';
---

<header class="header" data-header>
  <div class="header__col header__col--left">
    <button class="header__menu-btn" data-menu-toggle aria-label="Open menu" data-cursor="link">
      <span class="header__hamburger" aria-hidden="true">
        <span class="header__hamburger-line"><span></span></span>
        <span class="header__hamburger-line"><span></span></span>
      </span>
      <span class="header__menu-text">menu</span>
    </button>
  </div>

  <a class="header__col header__col--center" href={u('/')} aria-label="Federico de Servi — home" data-cursor="link">
    <span class="header__logo">federico de servi</span>
  </a>

  <a class="header__col header__col--right" href={u('/contact')} data-cursor="link">
    <span class="header__contact-text">scrivimi</span>
    <span class="header__contact-arrow" aria-hidden="true">↗</span>
  </a>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 2.4rem;
    padding: 1.6rem var(--padding-x);
    mix-blend-mode: difference;
    color: var(--brand-yellow);
    transition: opacity var(--d-micro) var(--easeOutQuart);
    pointer-events: none;
  }

  .header > * { pointer-events: auto; }

  @media (min-width: 768px) { .header { padding: 3.2rem var(--padding-x); } }
  @media (min-width: 1200px) {
    .header {
      grid-template-columns: 1fr 1fr 1fr;
      padding: 4.8rem var(--padding-x);
      gap: 0;
    }
    .header__col--left { justify-self: start; }
    .header__col--center { justify-self: center; }
    .header__col--right { justify-self: end; }
  }

  .header__col {
    display: inline-flex;
    align-items: center;
    color: var(--brand-yellow);
  }

  .header__col--left { order: 3; }
  .header__col--right { order: 2; }
  .header__col--center { order: 1; margin-right: auto; }

  @media (min-width: 1200px) {
    .header__col--left { order: 1; }
    .header__col--center { order: 2; }
    .header__col--right { order: 3; }
  }

  .header__menu-btn {
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
    color: var(--brand-yellow);
    font-family: var(--font-twk);
    font-weight: 400;
    font-size: 1.4rem;
    line-height: 1;
    letter-spacing: -0.042em;
  }

  .header__hamburger {
    position: relative;
    flex-shrink: 0;
    width: 2.4rem;
    height: 2.4rem;
  }

  @media (min-width: 1200px) {
    .header__hamburger { width: 1.6rem; height: 1.6rem; }
  }

  .header__hamburger-line {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, calc(-50% + var(--offset)));
    transform-origin: center;
    width: 100%;
    height: 0.1rem;
    overflow: hidden;
  }

  .header__hamburger-line span {
    position: absolute;
    inset: 0;
    background-color: var(--brand-yellow);
  }

  .header__hamburger-line:first-child { --offset: -0.3rem; }
  .header__hamburger-line:last-child  { --offset:  0.3rem; }

  .header__menu-text {
    display: none;
    overflow: clip;
  }
  @media (min-width: 1200px) { .header__menu-text { display: inline-block; } }

  .header__logo {
    font-family: var(--font-twk);
    font-weight: 700;
    font-size: 1.4rem;
    line-height: 1;
    letter-spacing: -0.042em;
    text-transform: lowercase;
  }
  @media (min-width: 1200px) { .header__logo { font-size: 1.6rem; } }

  .header__col--right {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .header__contact-text {
    font-family: var(--font-twk);
    font-weight: 400;
    font-size: 1.3rem;
    line-height: 1;
    letter-spacing: -0.039rem;
  }
  @media (min-width: 1200px) { .header__contact-text { font-size: 1.4rem; letter-spacing: -0.042rem; } }

  .header__contact-arrow {
    display: none;
    font-size: 1.2rem;
  }
  @media (min-width: 1200px) { .header__contact-arrow { display: inline-block; } }

  .header.is-hidden { opacity: 0; }
</style>

<script>
  const setup = () => {
    const header = document.querySelector<HTMLElement>('[data-header]');
    if (!header) return;
    let lastY = window.scrollY;
    let raf = 0;

    const onScroll = () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const y = window.scrollY;
        const goingDown = y > lastY && y > 200;
        header.classList.toggle('is-hidden', goingDown);
        lastY = y;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
  };

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
