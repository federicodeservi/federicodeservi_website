---
export interface Props {
  href: string;
  title: string;
  imageColor?: string; // CSS color for placeholder bg
  imageSrc?: string;
  alt?: string;
  ratio?: string; // aspect-ratio CSS, default '16/10'
}
const {
  href,
  title,
  imageColor = '#1740a9',
  imageSrc,
  alt = '',
  ratio = '16 / 10',
} = Astro.props;
---

<a class="case-thumb" href={href} data-cursor="image" data-parallax aria-label={title}>
  <div class="case-thumb__media" style={`aspect-ratio: ${ratio}; --thumb-color: ${imageColor};`}>
    {imageSrc ? (
      <img src={imageSrc} alt={alt} loading="lazy" decoding="async" />
    ) : (
      <div class="case-thumb__placeholder">
        <span class="case-thumb__placeholder-label">placeholder · {title}</span>
      </div>
    )}
    <div class="case-thumb__overlay">
      <slot name="services" />
    </div>
  </div>
</a>

<style>
  .case-thumb {
    display: block;
    position: relative;
    overflow: hidden;
    border-radius: var(--r-sm);
    cursor: none;
  }

  .case-thumb__media {
    position: relative;
    overflow: hidden;
    background: var(--thumb-color, var(--brand-blue));
    transition: transform var(--d-hover) var(--easeOutQuart),
                filter var(--d-hover) var(--easeOutQuart);
  }

  .case-thumb__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    will-change: transform;
  }

  .case-thumb__placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, var(--thumb-color, var(--brand-blue)) 0%, color-mix(in oklab, var(--thumb-color) 70%, #000) 100%);
    color: var(--brand-yellow);
  }

  .case-thumb__placeholder-label {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.5;
  }

  .case-thumb__overlay {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1.6rem 2rem;
    background: linear-gradient(to top, rgba(5, 18, 54, 0.85), transparent);
    color: var(--brand-yellow);
    font-family: var(--font-mono);
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transform: translateY(101%);
    transition: transform var(--d-hover) var(--easeOutQuart);
  }

  .case-thumb:hover .case-thumb__overlay {
    transform: translateY(0);
  }

  /* No-WebGL fallback hover effect */
  .case-thumb:hover .case-thumb__media {
    transform: scale(1.03);
    filter: brightness(1.05);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { reducedMotion } from '../lib/motion';

  gsap.registerPlugin(ScrollTrigger);

  const setup = () => {
    if (reducedMotion()) return;
    document.querySelectorAll<HTMLElement>('[data-parallax]').forEach((el) => {
      const img = el.querySelector<HTMLElement>('img, .case-thumb__placeholder');
      if (!img) return;
      ScrollTrigger.getAll().filter((t) => t.trigger === el).forEach((t) => t.kill());
      gsap.fromTo(
        img,
        { yPercent: -8 },
        {
          yPercent: 8,
          ease: 'none',
          scrollTrigger: { trigger: el, start: 'top bottom', end: 'bottom top', scrub: 1 },
        },
      );
    });
  };

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
