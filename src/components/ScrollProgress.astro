---
// Vertical scroll progress bar on the left edge, mix-blend-difference.
---

<div class="scroll-progress" data-scroll-progress aria-hidden="true">
  <div class="scroll-progress__bar"></div>
</div>

<style>
  .scroll-progress {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 0.2rem;
    height: 100svh;
    z-index: 80;
    pointer-events: none;
    mix-blend-mode: difference;
  }

  @media (min-width: 1200px) { .scroll-progress { display: block; } }

  .scroll-progress__bar {
    --progress: 0;
    width: 100%;
    height: 100%;
    background-color: var(--brand-yellow);
    transform-origin: top center;
    transform: scaleY(var(--progress));
    transition: transform 0.1s linear;
  }
</style>

<script>
  const setup = () => {
    const bar = document.querySelector<HTMLElement>('[data-scroll-progress] .scroll-progress__bar');
    if (!bar) return;
    let raf = 0;
    const onScroll = () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
        bar.style.setProperty('--progress', String(p));
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  };
  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
