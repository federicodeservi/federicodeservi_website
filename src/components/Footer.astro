---
import { u } from '../lib/url';
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__top">
    <div class="footer__col footer__col--name">
      <p class="footer__name">Federico de Servi</p>
      <p class="footer__role">Designer + brand-builder + flutter-dev</p>
      <p class="footer__role">Milano, IT — works remote</p>
    </div>

    <div class="footer__col">
      <h4>Sitemap</h4>
      <a href={u('/work')}>Work</a>
      <a href={u('/about')}>About</a>
      <a href={u('/contact')}>Contact</a>
    </div>

    <div class="footer__col">
      <h4>Elsewhere</h4>
      <a href="https://www.linkedin.com/in/federicodeservi" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
      <a href="https://www.behance.net/federicodeservi" target="_blank" rel="noopener noreferrer">Behance ↗</a>
      <a href="https://www.instagram.com/federicodeservi" target="_blank" rel="noopener noreferrer">Instagram ↗</a>
    </div>

    <div class="footer__col">
      <h4>Email</h4>
      <a href="mailto:federico@federicodeservi.com">federico@<br />federicodeservi.com</a>
    </div>
  </div>

  <div class="footer__bot">
    <span>© {currentYear} — Made in Milano</span>
    <span>Switzer + Inter + JetBrains Mono</span>
    <span>Built with Astro</span>
  </div>
</footer>

<style>
  .footer {
    padding: 6.4rem var(--pad) 4rem;
    border-top: 1px solid var(--rule);
    background: var(--bg);
    color: var(--ink);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 6.4rem;
    margin-bottom: 6.4rem;
  }

  .footer__col h4 {
    font-family: var(--font-mono);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    margin-bottom: 1.4rem;
    font-weight: 400;
  }

  .footer__col--name .footer__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.2rem;
    letter-spacing: -0.012em;
    margin-bottom: 0.4rem;
    color: var(--ink);
  }

  .footer__col--name .footer__role {
    color: var(--ink-muted);
    font-size: 1.4rem;
    line-height: 1.5;
  }

  .footer__col a {
    display: block;
    color: var(--ink);
    padding: 0.3rem 0;
    font-size: 1.3rem;
    transition: color 200ms, transform 200ms;
  }

  .footer__col a:hover {
    color: var(--accent-warm);
    transform: translateX(4px);
  }

  .footer__bot {
    padding-top: 2.4rem;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.2rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }

  @media (max-width: 900px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: 4rem;
      margin-bottom: 4rem;
    }
  }
</style>
