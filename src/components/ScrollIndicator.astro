---
// Bottom-center scroll indicator: dot + animated bar, mix-blend-difference.
// Hides itself once the user has scrolled past the first viewport.
---

<div class="scroll-ind" data-scroll-ind aria-hidden="true">
  <div class="scroll-ind__dot"></div>
  <div class="scroll-ind__bar">
    <div class="scroll-ind__bar-fill"></div>
  </div>
</div>

<style>
  .scroll-ind {
    position: fixed;
    bottom: 1.6rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    z-index: 18;
    pointer-events: none;
    mix-blend-mode: difference;
    transition: opacity var(--d-base) var(--easeOutQuart);
  }

  @media (min-width: 1200px) { .scroll-ind { bottom: 4.8rem; } }

  .scroll-ind.is-hidden { opacity: 0; }

  .scroll-ind__dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    border: 0.1rem solid #fff;
    transform: scale(0);
    animation: scroll-ind-dot 0.4s var(--easeOutQuart) 1.5s forwards;
  }

  @keyframes scroll-ind-dot {
    to { transform: scale(1); }
  }

  .scroll-ind__bar {
    position: relative;
    width: 0.1rem;
    height: 8rem;
    overflow: hidden;
  }

  .scroll-ind__bar-fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 0%, #fff 50%, transparent 100%);
    animation: scroll-ind-bar 3s linear infinite;
  }

  @keyframes scroll-ind-bar {
    from { transform: translateY(-100%); }
    to   { transform: translateY(100%); }
  }
</style>

<script>
  const setup = () => {
    const ind = document.querySelector<HTMLElement>('[data-scroll-ind]');
    if (!ind) return;
    const onScroll = () => {
      ind.classList.toggle('is-hidden', window.scrollY > window.innerHeight * 0.4);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  };
  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
